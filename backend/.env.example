# TruthLayer AI - Environment Configurations

# Server Port
PORT=5000

# Hugging Face API Key (Active AI Pipeline Driver)
# Get a token from Hugging Face: https://huggingface.co/settings/tokens
HF_API_KEY=

# Live Search API - Tavily (Orchestrates live web facts synthesis)
# Get a key from Tavily: https://tavily.com/
TAVILY_API_KEY=

# Live Search API - SerpAPI (Fallback web search engine engine)
# Get a key from SerpAPI: https://serpapi.com/
SERPAPI_API_KEY=
